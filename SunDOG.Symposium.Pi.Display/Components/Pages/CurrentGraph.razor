@using Radzen.Blazor
@using System.Timers
@using SunDOG.Symposium.Pi.Core
@rendermode InteractiveServer
@inject SensorDataStats DataStats

<style>
	html, body, .main, .content {
		background-color: @Style.BackgroundColor !important;
		margin: 0;
		padding: 0;
		min-height: 100vh;
	}

	.rz-chart {
		background-color: transparent !important;
	}

	.body {
		background-color: @Style.BackgroundColor;
		min-height: 100vh;
		width: 100%;
		margin: 0;
		padding: 2rem;
	}

	.stat-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 1rem 1.5rem;
		background-color: white;
		border: 2px solid @Style.DarkAccent; 
		border-radius: 8px;
		box-shadow: 2px 2px 8px rgba(0,0,0,0.05);
		min-width: 160px;
	}

	.stat-label {
		font-size: 0.85rem;
		color: @Style.DarkAccent;
		margin-bottom: 0.4rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.stat-value {
		font-size: 1.4rem;
		font-weight: 700;
		color: @Style.Black;
	}

		.stat-value.film {
			color: @Style.LightAccent;
		}

	/* Grid Layout */
	.stats-grid {
		display: flex;
		gap: 1.5rem;
		flex-wrap: wrap;
		margin-top: 3rem;
		justify-content: center;
	}
</style>

<div class="body">
	<h1>SunDOG Power Generation Demo</h1>

	<RadzenChart Style="background-color: transparent; width: 100%; height: 400px;">
		<RadzenCategoryAxis FormatString="{0:0.0} s" Padding="@Style.AxisPadding">
			<RadzenAxisTitle Text="Time (s)" />
			<RadzenGridLines Visible="false" />
		</RadzenCategoryAxis>

		<RadzenValueAxis>
			<RadzenAxisTitle Text="Current (mA)" />
			<RadzenGridLines Visible="false" />
		</RadzenValueAxis>

		<RadzenLineSeries Data="@Sensor1Readings" CategoryProperty="Time" ValueProperty="Value" Title="Base Panel" Stroke="@Style.SecondaryColor" StrokeWidth="@Style.LineWidth" />
		<RadzenLineSeries Data="@Sensor2Readings" CategoryProperty="Time" ValueProperty="Value" Title="Panel with Film" Stroke="@Style.PrimaryColor" StrokeWidth="@Style.LineWidth" />
	</RadzenChart>

	<div class="stats-grid">
		<div class="stat-card">
			<span class="stat-label">5s Avg (Base)</span>
			<span class="stat-value">@S1_5SAvg</span>
		</div>
		<div class="stat-card">
			<span class="stat-label">5s Avg (Film)</span>
			<span class="stat-value film">@S2_5SAvg</span>
		</div>

		<div class="stat-card">
			<span class="stat-label">10s Avg (Base)</span>
			<span class="stat-value">@S1_10SAvg</span>
		</div>
		<div class="stat-card">
			<span class="stat-label">10s Avg (Film)</span>
			<span class="stat-value film">@S2_10SAvg</span>
		</div>

		<div class="stat-card">
			<span class="stat-label">30s Avg (Base)</span>
			<span class="stat-value">@S1_30SAvg</span>
		</div>
		<div class="stat-card">
			<span class="stat-label">30s Avg (Film)</span>
			<span class="stat-value film">@S2_30SAvg</span>
		</div>
	</div>
</div>

@code {

	private ChartStyle Style = new ChartStyle();

	private Timer? _timer;

	private List<DataPoint> Sensor1Readings = new();
	private List<DataPoint> Sensor2Readings = new();

	private string S1_5SAvg = "";
	private string S1_10SAvg = "";
	private string S1_30SAvg = "";

	private string S2_5SAvg = "";
	private string S2_10SAvg = "";
	private string S2_30SAvg = "";

	private int counter = 0;

	protected override void OnInitialized()
	{
		_timer = new Timer(500);
		_timer.Elapsed += AddDataPoint;
		_timer.AutoReset = true;
		_timer.Enabled = true;
	}

	private void AddDataPoint(object? sender, ElapsedEventArgs e)
	{
		InvokeAsync(() =>
		{
			Sensor1Readings = DataStats.Sensor1_120SAverage.History();
			Sensor2Readings = DataStats.Sensor2_120SAverage.History();

			S1_5SAvg = $"{DataStats.Sensor1_5SAverage.Average:F3} mA";
			S1_10SAvg = $"{DataStats.Sensor1_10SAverage.Average:F3} mA";
			S1_30SAvg = $"{DataStats.Sensor1_30SAverage.Average:F3} mA";

			S2_5SAvg = $"{DataStats.Sensor2_5SAverage.Average:F3} mA";
			S2_10SAvg = $"{DataStats.Sensor2_10SAverage.Average:F3} mA";
			S2_30SAvg = $"{DataStats.Sensor2_30SAverage.Average:F3} mA";

			counter++;

			if (counter % 120 == 0)
			{
				GC.Collect(2, GCCollectionMode.Aggressive, true);
				counter = 0;
			}

			StateHasChanged();
		});
	}
}
